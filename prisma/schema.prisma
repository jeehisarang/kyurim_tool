// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Patient {
  id            Int            @id @default(autoincrement())
  chartNumber   String         @unique
  name          String
  memo          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  visits        Visit[]
  prescriptions Prescription[]
  messageLogs   MessageLog[]
  todoTasks     TodoTask[]
  patientNotes  PatientNote[]
  bodyCompositionRecords BodyCompositionRecord[]
  strengthTestRecords    StrengthTestRecord[]
}

model TreatmentCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  visits    Visit[]
}

model VisitType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  visits    Visit[]
}

model Visit {
  id                  Int               @id @default(autoincrement())
  patientId           Int
  patient             Patient           @relation(fields: [patientId], references: [id])
  visitDate           DateTime
  treatmentCategoryId Int
  treatmentCategory   TreatmentCategory @relation(fields: [treatmentCategoryId], references: [id])
  visitTypeId         Int
  visitType           VisitType         @relation(fields: [visitTypeId], references: [id])
  isReserved          Boolean
  createdAt           DateTime          @default(now())
  checkedByUserId     Int?
  checkedByUser       StaffUser?        @relation(fields: [checkedByUserId], references: [id])
  // 잘못 등록된 내원 체크 삭제용. TreatmentCategory/VisitType/StaffUser/Program과 동일한
  // 소프트 삭제 원칙(물리적 삭제 아님, 통계 정확성을 위해 비활성화만) — 통계/목록/카운트 조회 시
  // 반드시 isActive: true로 필터링할 것.
  isActive            Boolean           @default(true)
}

model StaffUser {
  id                      Int               @id @default(autoincrement())
  name                    String            @unique
  role                    String
  isActive                Boolean           @default(true)
  createdAt               DateTime          @default(now())
  visits                  Visit[]
  prescriptions           Prescription[]    @relation("PrescriptionStaff")
  todoTasks               TodoTask[]        @relation("TodoTaskStaff")
  doneTodoTasks           TodoTask[]        @relation("TodoTaskDoneBy")
  messageLogs             MessageLog[]
  skippedMessageLogs      MessageLog[]      @relation("MessageLogSkippedBy")
  patientNotes            PatientNote[]
  programEventLogs        ProgramEventLog[] @relation("ProgramEventLogStaff")
  skippedProgramEventLogs ProgramEventLog[] @relation("ProgramEventLogSkippedBy")
  bodyCompositionRecords  BodyCompositionRecord[]
  strengthTestRecords     StrengthTestRecord[]
}

model Program {
  id                Int                    @id @default(autoincrement())
  name              String                 @unique
  type              String // SPLIT(분할처방) | SINGLE(단회처방) | FIXED_SEQUENCE(고정 일자별 이벤트, 예: 킬팻캡슐 3일체험)
  splitIntervalDays Int?                   @default(14)
  totalDurationDays Int?                   @default(90)
  followUpDays      Int?
  isActive          Boolean                @default(true)
  sortOrder         Int                    @default(0)
  createdAt         DateTime               @default(now())
  prescriptions     Prescription[]
  eventTemplates    ProgramEventTemplate[]
}

// FIXED_SEQUENCE 타입 프로그램 전용: 등록 시점(Prescription.startDate) 기준으로
// 오프셋만큼 떨어진 날짜에 TodoTask를 몇 개 만들지 정의하는 템플릿.
// 예: 킬팻캡슐 3일체험 = TRIAL_WELCOME(0일) / TRIAL_DAY2(2일) / TRIAL_DEADLINE(3일).
model ProgramEventTemplate {
  id             Int      @id @default(autoincrement())
  programId      Int
  program        Program  @relation(fields: [programId], references: [id])
  taskType       String // 예: TRIAL_WELCOME | TRIAL_DAY2 | TRIAL_DEADLINE
  offsetDays     Int
  generationType String // FIXED | AI
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  @@unique([programId, taskType])
}

model Prescription {
  id             Int        @id @default(autoincrement())
  patientId      Int
  patient        Patient    @relation(fields: [patientId], references: [id])
  programId      Int
  program        Program    @relation(fields: [programId], references: [id])
  startDate      DateTime
  currentRound   Int?
  totalRounds    Int?
  staffUserId    Int
  staffUser      StaffUser  @relation("PrescriptionStaff", fields: [staffUserId], references: [id])
  status         String     @default("ACTIVE") // ACTIVE | COMPLETED | STOPPED
  // FIXED_SEQUENCE 프로그램(예: 킬팻캡슐 3일체험)의 설문 데이터 필드.
  // 정형 스키마 아님 — 자유 텍스트. 직원이 직접 입력하거나(자유형식), SurveyResponseCache에서
  // 골라 채워넣는 반자동 방식(구글폼 연동) 둘 다로 채워질 수 있음.
  surveyDataJson String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  todoTasks      TodoTask[]
  bodyCompositionRecords BodyCompositionRecord[]
  strengthTestRecords    StrengthTestRecord[]
}

// 13-6 검사: 인바디(체성분) 기록. 이번 범위는 "체중 위주 감량추이 확인"이 핵심이라
// 체중 중심의 단순 구조로 시작 — 체성분 세부수치는 필요시 향후 확장.
model BodyCompositionRecord {
  id             Int           @id @default(autoincrement())
  patientId      Int
  patient        Patient       @relation(fields: [patientId], references: [id])
  // 측정 당시 진행 중이던 처방(선택사항) — 자동매칭 없음, 직원이 목록에서 직접 선택.
  prescriptionId Int?
  prescription   Prescription? @relation(fields: [prescriptionId], references: [id])
  measuredAt     DateTime
  weightKg       Float
  note           String?
  staffUserId    Int
  staffUser      StaffUser     @relation(fields: [staffUserId], references: [id])
  createdAt      DateTime      @default(now())
}

// 13-6 검사: 근력검사(SMI지표 + 악력) 기록.
// smi/smiJudgement/gripAvgKg/gripJudgement는 계산값이지만 저장 시점 값을 그대로 고정 저장한다 —
// 판정기준(src/lib/exam-thresholds.ts)이 나중에 바뀌어도 과거 판정이 소급 변경되지 않도록 하기 위함.
model StrengthTestRecord {
  id                   Int           @id @default(autoincrement())
  patientId            Int
  patient              Patient       @relation(fields: [patientId], references: [id])
  prescriptionId       Int?
  prescription         Prescription? @relation(fields: [prescriptionId], references: [id])
  measuredAt           DateTime
  gender               String // MALE | FEMALE — 측정시점 스냅샷(Patient에 성별 필드가 없음)
  measuredAge          Int // 측정시점 나이 스냅샷 — 악력 판정표의 연령대 구간 조회용
  heightCm             Float
  armMuscleMassLeftKg  Float
  armMuscleMassRightKg Float
  legMuscleMassLeftKg  Float
  legMuscleMassRightKg Float
  smi                  Float
  smiJudgement         String // NORMAL | SARCOPENIA
  gripLeftKg           Float
  gripRightKg          Float
  gripAvgKg            Float
  gripJudgement        String // WEAK | NORMAL | STRONG | UNKNOWN(판정불가, 예: 20세 미만)
  staffUserId          Int
  staffUser            StaffUser     @relation(fields: [staffUserId], references: [id])
  createdAt            DateTime      @default(now())
}

model TodoTask {
  id             Int              @id @default(autoincrement())
  prescriptionId Int?
  prescription   Prescription?    @relation(fields: [prescriptionId], references: [id])
  patientId      Int?
  patient        Patient?         @relation(fields: [patientId], references: [id])
  taskType       String // NEXT_DOSE | FOLLOW_UP (처방) | DAY2 | DAY7 | THIRD_VISIT | TRIAL_WELCOME | TRIAL_DAY2 | TRIAL_DEADLINE (톡)
  dueDate        DateTime
  staffUserId    Int?
  staffUser      StaffUser?       @relation("TodoTaskStaff", fields: [staffUserId], references: [id])
  isDone         Boolean          @default(false)
  doneByUserId   Int?
  doneByUser     StaffUser?       @relation("TodoTaskDoneBy", fields: [doneByUserId], references: [id])
  doneAt         DateTime?
  createdAt      DateTime         @default(now())
  eventLog       ProgramEventLog?
}

// FIXED_SEQUENCE 프로그램의 톡류 TodoTask 1건과 1:1 대응하는 발송 로그.
// MessageLog(@@unique([patientId, messageType]))는 환자당 타입 하나만 허용해서
// 재등록(예: 3일체험 재신청) 시 유니크 충돌이 나므로 재사용하지 않고 별도 테이블로 분리함 —
// TodoTask 1건마다 로그가 새로 생기니 재등록해도 충돌이 구조적으로 없음.
model ProgramEventLog {
  id               Int        @id @default(autoincrement())
  todoTaskId       Int        @unique
  todoTask         TodoTask   @relation(fields: [todoTaskId], references: [id])
  sentDate         DateTime?
  staffUserId      Int?
  staffUser        StaffUser? @relation("ProgramEventLogStaff", fields: [staffUserId], references: [id])
  skippedAt        DateTime?
  skippedByUserId  Int?
  skippedByUser    StaffUser? @relation("ProgramEventLogSkippedBy", fields: [skippedByUserId], references: [id])
  // 환자발송용 메시지(복사 대상)
  patientMessage   String?
  // 원장용 내부분석(타입/처방방향/상담포인트 등) — 복사 버튼 없이 원장만 보는 용도
  internalAnalysis String?
  createdAt        DateTime   @default(now())
}

model MessageLog {
  id              Int        @id @default(autoincrement())
  patientId       Int
  patient         Patient    @relation(fields: [patientId], references: [id])
  messageType     String // WELCOME | MEETING | DAY2 | DAY7 | THIRD_VISIT
  sentDate        DateTime?
  staffUserId     Int?
  staffUser       StaffUser? @relation(fields: [staffUserId], references: [id])
  skippedAt       DateTime?
  skippedByUserId Int?
  skippedByUser   StaffUser? @relation("MessageLogSkippedBy", fields: [skippedByUserId], references: [id])
  aiDraftContent  String?
  createdAt       DateTime   @default(now())

  @@unique([patientId, messageType])
}

model PatientNote {
  id          Int       @id @default(autoincrement())
  patientId   Int
  patient     Patient   @relation(fields: [patientId], references: [id])
  content     String
  staffUserId Int
  staffUser   StaffUser @relation(fields: [staffUserId], references: [id])
  createdAt   DateTime  @default(now())
}

// 킬팻캡슐 3일체험 등록(구글폼) 응답을 시트에서 폴링해 캐싱해두는 테이블.
// 완전 자동매칭은 하지 않고, 직원이 /prescriptions/new 화면에서 이 목록 중 골라
// surveyDataJson에 채워넣는 반자동 방식의 소스 데이터로만 사용한다.
model SurveyResponseCache {
  id                   Int      @id @default(autoincrement())
  // 시트상 행 식별용(타임스탬프+이름+연락처 조합) — 재폴링 시 중복 적재 방지
  sourceRowId          String   @unique
  respondentName       String
  respondentPhone      String
  // 행 전체를 헤더-값 매핑 JSON 문자열로 보관(텍스트 정리 시 재사용)
  rawDataJson          String
  fetchedAt            DateTime @default(now())
  // 실제 Prescription과의 FK 관계는 두지 않음 — 이 캐시는 어디까지나 선택 참고용 소스라
  // 처방 삭제/재등록 흐름에 얽히지 않게 느슨한 참조(문자열)로만 남긴다(13-4 대비 기초 작업).
  linkedPrescriptionId String?
}

model Goal {
  id          Int      @id @default(autoincrement())
  metricKey   String
  periodType  String
  periodStart DateTime
  targetValue Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([metricKey, periodType, periodStart])
}
