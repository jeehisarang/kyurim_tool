// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Patient {
  id                          Int                     @id @default(autoincrement())
  chartNumber                 String                  @unique
  name                        String
  memo                        String?
  // 핵심프로필(14-3) — PatientNote(로그형 누적 메모)와 달리 "최신 상태"만 유지하는 요약
  // 필드. 상황이 바뀌면 덮어쓰는 방식이며, 원장만 수정할 수 있다(서버단 role 재검증 필수 —
  // /api/patients/[id]/core-profile 참고). 한차트(정식 의료기록)와는 별개 목적이라
  // memo/PatientNote와 내용이 겹쳐도 무방.
  pastHistory                 String?
  currentCondition            String?
  mainNeeds                   String?
  // 인바디(체성분) 검사용 고정값. 최초 인바디 등록 시 입력받아 저장하고,
  // 이후 등록에서는 재입력 없이 그대로 재사용한다(측정 시점마다 바뀌는 값이 아님).
  height                      Float?
  // MALE | FEMALE — SMI 근감소증 판정(exam-thresholds.ts)에 필요. height와 동일한 고정값 패턴.
  gender                      String?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  visits                      Visit[]
  prescriptions               Prescription[]
  messageLogs                 MessageLog[]
  todoTasks                   TodoTask[]
  patientNotes                PatientNote[]
  bodyCompositionRecords      BodyCompositionRecord[]
  strengthTestRecords         StrengthTestRecord[]
  hrvTestRecords              HrvTestRecord[]
  teachingPages               PatientTeachingPage[]
  consultationNotes           ConsultationNote[]
  shareLinks                  PatientShareLink[]
  hrvImportPendingResolutions HrvImportPending[]
  tcmChecklistResponses       TcmChecklistResponse[]
}

model TreatmentCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  visits    Visit[]
}

// 원장 상담모드(14-5) 전용 — 초진상담/한약상담/인바디상담 등 상담유형 커스텀 마스터.
// TreatmentCategory/VisitType과 동일한 패턴(자유롭게 추가/수정/비활성화 가능).
model ConsultationType {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  isActive          Boolean            @default(true)
  sortOrder         Int                @default(0)
  createdAt         DateTime           @default(now())
  consultationNotes ConsultationNote[]
}

model VisitType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  visits    Visit[]
}

model Visit {
  id                  Int               @id @default(autoincrement())
  patientId           Int
  patient             Patient           @relation(fields: [patientId], references: [id])
  visitDate           DateTime
  treatmentCategoryId Int
  treatmentCategory   TreatmentCategory @relation(fields: [treatmentCategoryId], references: [id])
  visitTypeId         Int
  visitType           VisitType         @relation(fields: [visitTypeId], references: [id])
  isReserved          Boolean
  createdAt           DateTime          @default(now())
  checkedByUserId     Int?
  checkedByUser       StaffUser?        @relation(fields: [checkedByUserId], references: [id])
  // 잘못 등록된 내원 체크 삭제용. TreatmentCategory/VisitType/StaffUser/Program과 동일한
  // 소프트 삭제 원칙(물리적 삭제 아님, 통계 정확성을 위해 비활성화만) — 통계/목록/카운트 조회 시
  // 반드시 isActive: true로 필터링할 것.
  isActive            Boolean           @default(true)
}

model StaffUser {
  id                        Int                     @id @default(autoincrement())
  name                      String                  @unique
  role                      String
  isActive                  Boolean                 @default(true)
  createdAt                 DateTime                @default(now())
  visits                    Visit[]
  prescriptions             Prescription[]          @relation("PrescriptionStaff")
  todoTasks                 TodoTask[]              @relation("TodoTaskStaff")
  doneTodoTasks             TodoTask[]              @relation("TodoTaskDoneBy")
  messageLogs               MessageLog[]
  skippedMessageLogs        MessageLog[]            @relation("MessageLogSkippedBy")
  patientNotes              PatientNote[]
  programEventLogs          ProgramEventLog[]       @relation("ProgramEventLogStaff")
  skippedProgramEventLogs   ProgramEventLog[]       @relation("ProgramEventLogSkippedBy")
  bodyCompositionRecords    BodyCompositionRecord[]
  strengthTestRecords       StrengthTestRecord[]
  hrvTestRecords            HrvTestRecord[]
  createdWorkTasks          WorkTask[]              @relation("WorkTaskCreator")
  assignedWorkTasks         WorkTask[]              @relation("WorkTaskAssignee")
  announcements             Announcement[]
  createdTeachingPages      PatientTeachingPage[]   @relation("TeachingPageCreator")
  consultationNotes         ConsultationNote[]
  createdEventImages        EventImage[]            @relation("EventImageCreator")
  createdShareLinks         PatientShareLink[]      @relation("ShareLinkCreator")
  checkedActivityLogs       ActivityLog[]
  resolvedHrvImportPendings HrvImportPending[]
  tcmChecklistResponses     TcmChecklistResponse[]
}

model Program {
  id                Int                    @id @default(autoincrement())
  name              String                 @unique
  type              String // SPLIT(분할처방) | SINGLE(단회처방) | FIXED_SEQUENCE(고정 일자별 이벤트, 예: 킬팻캡슐 3일체험)
  splitIntervalDays Int?                   @default(14)
  totalDurationDays Int?                   @default(90)
  followUpDays      Int?
  isActive          Boolean                @default(true)
  sortOrder         Int                    @default(0)
  createdAt         DateTime               @default(now())
  prescriptions     Prescription[]
  eventTemplates    ProgramEventTemplate[]
}

// FIXED_SEQUENCE 타입 프로그램 전용: 등록 시점(Prescription.startDate) 기준으로
// 오프셋만큼 떨어진 날짜에 TodoTask를 몇 개 만들지 정의하는 템플릿.
// 예: 킬팻캡슐 3일체험 = TRIAL_WELCOME(0일) / TRIAL_DAY2(2일) / TRIAL_DEADLINE(3일).
model ProgramEventTemplate {
  id             Int      @id @default(autoincrement())
  programId      Int
  program        Program  @relation(fields: [programId], references: [id])
  taskType       String // 예: TRIAL_WELCOME | TRIAL_DAY2 | TRIAL_DEADLINE
  offsetDays     Int
  generationType String // FIXED | AI
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  @@unique([programId, taskType])
}

model Prescription {
  id                     Int                         @id @default(autoincrement())
  patientId              Int
  patient                Patient                     @relation(fields: [patientId], references: [id])
  programId              Int
  program                Program                     @relation(fields: [programId], references: [id])
  startDate              DateTime
  currentRound           Int?
  totalRounds            Int?
  staffUserId            Int
  staffUser              StaffUser                   @relation("PrescriptionStaff", fields: [staffUserId], references: [id])
  status                 String                      @default("ACTIVE") // ACTIVE | COMPLETED | STOPPED
  // FIXED_SEQUENCE 프로그램(예: 킬팻캡슐 3일체험)의 설문 데이터 필드.
  // 정형 스키마 아님 — 자유 텍스트. 직원이 직접 입력하거나(자유형식), SurveyResponseCache에서
  // 골라 채워넣는 반자동 방식(구글폼 연동) 둘 다로 채워질 수 있음.
  surveyDataJson         String?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  todoTasks              TodoTask[]
  bodyCompositionRecords BodyCompositionRecord[]
  strengthTestRecords    StrengthTestRecord[]
  roundOverrides         PrescriptionRoundOverride[]
}

// SPLIT 타입 처방의 회차별 예정일을 직원이 개별 수동 조정한 값 — roundNumber당 최대
// 1건, 있으면 computeSplitSchedule 계산값 대신 이 날짜를 쓴다. 실사용 중 환자가 정확히
// 2주 간격으로 안 오는 경우가 흔해서(task.md) 도입 — 수정한 회차 하나만 바뀌고
// 앞뒤 다른 회차는 원래 계산대로 유지되는 것이 핵심(연쇄 재계산 없음).
model PrescriptionRoundOverride {
  id             Int          @id @default(autoincrement())
  prescriptionId Int
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  roundNumber    Int
  overrideDate   DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([prescriptionId, roundNumber])
}

// 13-6 검사: 인바디(체성분) 기록. 핵심 입력은 체중/체지방율/WHR 3개이고, 사지골격근량
// 4개(팔좌우/다리좌우)는 선택 입력 — 4개 다 입력된 경우에만 limbMuscleMassKg/smi/
// smiJudgement를 계산해서 같이 저장한다(하나라도 비면 셋 다 null).
// smi/smiJudgement는 계산값이지만 StrengthTestRecord와 동일하게 저장 시점 값을 그대로
// 고정 저장한다 — 판정기준(exam-thresholds.ts)이 나중에 바뀌어도 과거 판정이 소급
// 변경되지 않도록 하기 위함. BMI는 별도 컬럼으로 저장하지 않고 화면에서
// weightKg/Patient.height로 실시간 계산해 표시만 한다.
model BodyCompositionRecord {
  id                   Int           @id @default(autoincrement())
  patientId            Int
  patient              Patient       @relation(fields: [patientId], references: [id])
  // 측정 당시 진행 중이던 처방(선택사항) — 자동매칭 없음, 직원이 목록에서 직접 선택.
  prescriptionId       Int?
  prescription         Prescription? @relation(fields: [prescriptionId], references: [id])
  // 실제 검사가 이뤄진 날짜(소급 입력 가능) — createdAt(시스템 기록 생성 시각)과 별개.
  // 반드시 자정(00:00:00) 기준으로 저장할 것 — Visit.visitDate와 동일한 이유로, 시:분:초가
  // 섞이면 날짜별 목록 조회/정렬이 어긋난다(과거 트러블슈팅 히스토리 참고).
  examDate             DateTime
  weightKg             Float
  bodyFatPercent       Float
  whr                  Float
  armMuscleMassLeftKg  Float?
  armMuscleMassRightKg Float?
  legMuscleMassLeftKg  Float?
  legMuscleMassRightKg Float?
  limbMuscleMassKg     Float?
  smi                  Float?
  smiJudgement         String? // NORMAL | SARCOPENIA
  note                 String?
  // AI 해설 코멘트(task.md) — 저장 시점에 동기 생성해서 캐싱. 과거 레코드는 null로
  // 남아있다가 "환자와 함께보기" 열람 시 즉석 생성 후 이 필드에 채워 재사용한다.
  aiExplanation        String?
  staffUserId          Int
  staffUser            StaffUser     @relation(fields: [staffUserId], references: [id])
  createdAt            DateTime      @default(now())
  // 소프트 삭제 원칙(Visit/Program 등과 동일) — 물리 삭제 대신 비활성화만. 통계/목록/추이
  // 조회 시 반드시 isActive: true로 필터링할 것(task2.md).
  isActive             Boolean       @default(true)
}

// 13-6 검사: 근력검사(악력 + 근력나이) 기록. SMI/근감소증 진단은 인바디(BodyCompositionRecord)
// 에서만 담당한다 — 근감소증 진단기준 (1)SMI와 (2)악력은 원래 서로 다른 두 지표라 통합할
// 필요가 없고, 여기서는 사지골격근량/키/SMI 입력을 걷어내 순수하게 악력만 다룬다.
// gripAvgKg/gripJudgement/estimatedGripAge/gripAgeOutOfRange는 계산값이지만 저장 시점 값을
// 그대로 고정 저장한다 — 판정기준(src/lib/exam-thresholds.ts)이 나중에 바뀌어도 과거 판정이
// 소급 변경되지 않도록 하기 위함.
// gender는 자체 필드를 두지 않고 Patient.gender를 참조한다(BodyCompositionRecord와 동일 패턴).
model StrengthTestRecord {
  id                Int           @id @default(autoincrement())
  patientId         Int
  patient           Patient       @relation(fields: [patientId], references: [id])
  prescriptionId    Int?
  prescription      Prescription? @relation(fields: [prescriptionId], references: [id])
  // 실제 검사가 이뤄진 날짜(소급 입력 가능) — createdAt과 별개, 자정(00:00:00) 기준 저장.
  // BodyCompositionRecord.examDate와 동일한 원칙.
  examDate          DateTime
  measuredAge       Int // 측정시점 나이 스냅샷 — 악력 판정표의 연령대 구간 조회용
  gripLeftKg        Float
  gripRightKg       Float
  gripAvgKg         Float
  gripJudgement     String // WEAK | NORMAL | STRONG | UNKNOWN(판정불가, 예: 20세 미만)
  estimatedGripAge  Int? // 또래 평균 대비 환산 나이 — 범위초과 시 null(gripAgeOutOfRange만 채워짐)
  gripAgeOutOfRange String? // young(20세 미만) | old(80세 이상)
  // AI 해설 코멘트(task.md) — BodyCompositionRecord.aiExplanation과 동일 원칙.
  aiExplanation     String?
  staffUserId       Int
  staffUser         StaffUser     @relation(fields: [staffUserId], references: [id])
  createdAt         DateTime      @default(now())
  // 소프트 삭제 원칙(Visit/Program 등과 동일) — 물리 삭제 대신 비활성화만(task2.md).
  isActive          Boolean       @default(true)
}

// 자율신경맥파기(HRV) 검사(task2.md) — 기기가 이미 완성된 판정까지 포함한 결과지를
// 만들어내므로, 이 앱은 판정 계산 로직 없이 핵심 수치 몇 개만 기록해 추이 추적 +
// 원본 결과지 이미지 보존 + AI 해설 생성 역할만 담당한다.
model HrvTestRecord {
  id                    Int        @id @default(autoincrement())
  patientId             Int
  patient               Patient    @relation(fields: [patientId], references: [id])
  // 실제 검사가 이뤄진 날짜 — BodyCompositionRecord.examDate와 동일한 원칙(자정 기준 저장).
  testDate              DateTime
  vascularHealthIndex   Float
  // 기기가 판정한 혈관건강도 타입 문자열 그대로 저장(예: "양호") — 이 앱이 재판정하지 않음.
  vascularHealthType    String
  avgPulse              Float
  // 유비오맥파 CSV 자동연동(task.md) — "혈관건강도 측정"만 하고 "스트레스 지수 측정"까지
  // 안 하면 기기 자체가 이 값을 아예 안 낸다. 수동 등록 화면은 여전히 필수 입력으로 강제하고
  // 있어(POST /api/hrv-records 검증 로직 불변) 실질적으로 null인 경우는 자동연동 경로에서만
  // 생긴다. UI는 null이면 "측정 안 함"으로 표시하고 색상강조/AI 코멘트 언급을 건너뛴다.
  stressIndex           Float?
  // 상세 HRV 지표(task.md, 유비오맥파 CSV 자동연동) — 아직 어느 화면에도 노출하지 않고
  // 향후 "HRV 학술근거 확장" 때 재파싱 없이 바로 쓰기 위해 미리 확보만 해둔다. CSV의 원본
  // 컬럼명 그대로 대응: TP(Ln)→tp, VLF(Ln)→vlf, LF(Ln)→lf, HF(Ln)→hf, LF/HF→lfHfRatio,
  // SDNN→sdnn, RMSSD→rmssd. 수동 등록 경로는 이 필드들을 채우지 않는다(항상 null).
  tp                    Float?
  vlf                   Float?
  lf                    Float?
  hf                    Float?
  lfHfRatio             Float?
  sdnn                  Float?
  rmssd                 Float?
  // 구글드라이브에서 다운로드한 원본 결과지 이미지(리사이즈/압축 후 로컬 저장 경로).
  // 기기 리포트는 항상 2장(1p 요약/2p 상세)이라 두 번째 장을 별도 필드로 추가했다(task.md) —
  // 과거 1장짜리 레코드는 sourceImagePath2가 null로 남아 회귀 없이 그대로 조회된다.
  sourceImagePath       String
  sourceImagePath2      String?
  // AI 해설 코멘트(레거시) — 4단 구조를 하나의 문단으로 이어 붙여 저장하던 과거 방식.
  // 신규 레코드는 대신 아래 4개 필드에 구조화 저장하고 이 필드는 비워둔다(task.md) —
  // 과거 레코드 회귀 방지를 위해 필드/데이터를 그대로 남겨두고, 화면 표시 시 구조화 필드가
  // 비어있으면 이 필드로 폴백한다.
  aiCommentary          String?
  // AI 코멘트 4단 구조 구조화 저장(task.md) — ①기기판독 ②임상적의미 ③생활관리 ④한의학적해석.
  // ProgramTeachingCreator와 동일하게 섹션별 수작업 편집(원장 전용 화면)을 지원하기 위해
  // 하나의 텍스트가 아니라 필드를 분리했다.
  aiDeviceReading       String?
  aiClinicalMeaning     String?
  aiLifestyleGuide      String?
  aiTcmInterpretation   String?
  // 위 4필드가 어느 프롬프트 버전으로 생성됐는지(task.md "미병" 재설계, 이후 "건강 리포트"
  // 7카드 리뉴얼) — null이면 구버전(기기판독요약/임상적의미/생활관리안내/한의학적해석),
  // "MIBYEONG_V1"이면 미병 재설계(미병도입/결과와추이/한의학적해석/양생안내),
  // "HEALTH_REPORT_V1"이면 7카드 건강 리포트(task.md) — 이때 슬롯 재사용 의미가 또 달라진다:
  // aiDeviceReading=카드1 헤드라인+경과문장, aiClinicalMeaning=카드3 주목할 변화(코드 생성,
  // AI 아님), aiLifestyleGuide=카드7 치료방향+생활관리, aiTcmInterpretation=카드4(투명성
  // 문구 추가). 슬롯 4개는 그대로 재사용하되 콘텐츠 종류 자체가 달라져서 UI가 라벨/순서를
  // 통째로 스위치해야 하므로 이 필드로 구분한다(taskType/examType과 동일한 문자열 판별자
  // 관례). AI 코멘트 생성/재생성 시점에만 채워지고, 캐시된 값을 그대로 반환하는 경로는
  // 건드리지 않는다.
  aiCommentaryVersion   String?
  // 아래 3개는 HEALTH_REPORT_V1 전용 신규 필드(task.md 7카드 리뉴얼) — 이전 버전 슬롯 4개에
  // 대응 자리가 없어 새로 추가했다. MIBYEONG_V1 이하 레코드는 항상 null.
  // 카드5 "이런 경향이 지속되면" — 질병명 없이 증상 수준 경과만 서술하는 AI 생성 문단.
  aiProgressionCard     String?
  // 카드2 "내가 선택한 증상" — 생성 시점 TcmChecklistResponse에서 후보 카테고리의 "경미하다/
  // 심하다" 응답 문항 문구를 코드가 그대로 뽑아 JSON 배열로 스냅샷한다(AI가 만들지 않음 —
  // 지어내거나 왜곡할 위험을 원천 차단, task.md 검증체크리스트 "지어내지 않는지" 요건).
  aiCheckedSymptomsJson String?
  // 카드6 위험신호 — 후보 카테고리의 TcmCategory.redFlagNotice를 생성 시점에 코드가 그대로
  // 스냅샷한다(ensureArrhythmiaNotice와 동일 원칙: AI가 안 만들고 시스템이 결정적으로 삽입).
  // null이면 카드 자체를 숨긴다.
  aiRedFlagNotice       String?
  // 유비오맥파 CSV 자동연동(task.md)으로 생성된 레코드는 담당 직원 정보가 CSV에 없어 null —
  // 화면은 "자동연동"으로 표시한다. 수동 등록 경로(POST /api/hrv-records)는 그대로 항상 채운다.
  measuredByStaffId     Int?
  measuredByStaff       StaffUser? @relation(fields: [measuredByStaffId], references: [id])
  createdAt             DateTime   @default(now())
  // 소프트 삭제 원칙(Visit/Program 등과 동일) — 물리 삭제 대신 비활성화만(task2.md).
  isActive              Boolean    @default(true)
  // 유비오맥파 CSV 자동연동(task.md) 전용 — "사용자명|측정일시(ISO)" 조합. 같은 CSV 행을
  // 재스캔해도 이 유니크값으로 중복 생성을 막는다(수동 등록 레코드는 항상 null).
  csvSourceKey          String?    @unique
}

// 유비오맥파 CSV 자동연동(task.md) — CSV의 "번호"(차트번호) 필드가 비어있거나 일치하는
// 환자를 못 찾은 행을 여기 임시 보관한다. 직원이 화면에서 환자를 수동 지정하면
// createHrvTestRecord()로 정식 HrvTestRecord를 만들고 이 행은 RESOLVED로 남긴다(감사이력
// 겸 재스캔 시 중복방지 — userName+measuredAt 유니크 제약 자체가 dedup 역할도 한다).
model HrvImportPending {
  id                      Int        @id @default(autoincrement())
  userName                String
  gender                  String?
  birthYear               Int?
  age                     Int?
  // CSV의 "번호" 필드 원본값 — 비어있을 수도, 있지만 매칭 실패했을 수도 있다(직원이 화면에서
  // 참고할 수 있게 그대로 보존).
  rawChartNumber          String?
  measuredAt              DateTime
  vascularHealthIndex     Float?
  vascularHealthType      String?
  avgPulse                Float?
  stressIndex             Float?
  tp                      Float?
  vlf                     Float?
  lf                      Float?
  hf                      Float?
  lfHfRatio               Float?
  sdnn                    Float?
  rmssd                   Float?
  // capture 폴더에서 매칭된 캡처 이미지를 saveHrvResultImage로 미리 저장해둔 경로(있으면) —
  // 대기열 화면에서 바로 썸네일을 보여주기 위함. 없으면 null(그래도 대기열 항목 자체는 생성).
  capturedImagePath       String?
  // 어느 csv 파일에서 왔는지(추적용).
  sourceFile              String
  status                  String     @default("PENDING") // PENDING | RESOLVED | IGNORED
  resolvedPatientId       Int?
  resolvedPatient         Patient?   @relation(fields: [resolvedPatientId], references: [id])
  resolvedByStaffId       Int?
  resolvedByStaff         StaffUser? @relation(fields: [resolvedByStaffId], references: [id])
  resolvedHrvTestRecordId Int?
  resolvedAt              DateTime?
  createdAt               DateTime   @default(now())

  @@unique([userName, measuredAt])
}

// 검사종류별 원장 작성 학술 근거 텍스트 — 향후 다른 검사종류(예: 소변검사) 추가 시
// examType만 늘려서 재사용 가능하게 범용으로 설계했다(task2.md).
model ExamAcademicGuide {
  id                Int      @id @default(autoincrement())
  examType          String   @unique // 현재는 "HRV" 고정값
  content           String
  // 한의학적 가능성 매핑표(task.md 최종 통합본) — [{symptoms, pattern, phrase}] JSON 배열.
  // AI 코멘트 4단계(한의학적 해석)에서 환자 증상기록과 대조할 때만 참고재료로 쓰인다.
  tcmPatternMapJson String?
  updatedAt         DateTime @updatedAt
}

model TodoTask {
  id             Int              @id @default(autoincrement())
  prescriptionId Int?
  prescription   Prescription?    @relation(fields: [prescriptionId], references: [id])
  patientId      Int?
  patient        Patient?         @relation(fields: [patientId], references: [id])
  taskType       String // NEXT_DOSE | FOLLOW_UP (처방) | DAY2 | DAY7 | THIRD_VISIT | TRIAL_WELCOME | TRIAL_DAY2 | TRIAL_DEADLINE (톡) | WORK (업무/요청)
  // WORK는 마감일이 선택사항이라 nullable — 그 외 타입은 관례상 항상 값이 채워진다.
  // 값이 있으면 반드시 자정(00:00:00) 기준으로 저장(examDate/visitDate와 동일 원칙).
  dueDate        DateTime?
  staffUserId    Int?
  staffUser      StaffUser?       @relation("TodoTaskStaff", fields: [staffUserId], references: [id])
  isDone         Boolean          @default(false)
  doneByUserId   Int?
  doneByUser     StaffUser?       @relation("TodoTaskDoneBy", fields: [doneByUserId], references: [id])
  doneAt         DateTime?
  createdAt      DateTime         @default(now())
  eventLog       ProgramEventLog?
  workTask       WorkTask?
}

// 업무/요청(taskType='WORK') TodoTask 1건과 1:1 대응하는 상세 정보.
// 완료 처리는 다른 체크형(NEXT_DOSE/FOLLOW_UP)과 동일하게 TodoTask.isDone/doneByUserId/doneAt가
// 진실원천이다 — ProgramEventLog/MessageLog 같은 메시지형과 달리 별도 완료 로그를 두지 않는다
// (완료가 체크 1번으로 끝나는 단순한 성격이라 굳이 분리할 이유가 없음).
// TodoTask.staffUserId는 assigneeId(없으면 creatorId, 즉 자율업무는 본인)로 채워서 기존
// "담당자" 필터/컬럼이 그대로 재사용되게 한다.
model WorkTask {
  id           Int        @id @default(autoincrement())
  todoTaskId   Int        @unique
  todoTask     TodoTask   @relation(fields: [todoTaskId], references: [id])
  title        String
  description  String?
  creatorId    Int
  creator      StaffUser  @relation("WorkTaskCreator", fields: [creatorId], references: [id])
  // 비어있으면 "자율업무"(작성자 본인이 알아서 할 일) — 화면에서 구분 표시만, 로직은 동일.
  // isSharedTask가 true면 assigneeId는 항상 null(특정 1인이 아니라 전체 공통이므로)이고,
  // 대신 모든 활성 StaffUser의 할일 목록에 동일하게 노출된다 — 아무나 체크하면 그 한 행이
  // 즉시 완료 처리되어 전체 화면에 반영된다(행 자체가 공용이라 별도 동기화 로직 불필요).
  assigneeId   Int?
  assignee     StaffUser? @relation("WorkTaskAssignee", fields: [assigneeId], references: [id])
  isSharedTask Boolean    @default(false)
  createdAt    DateTime   @default(now())
}

// FIXED_SEQUENCE 프로그램의 톡류 TodoTask 1건과 1:1 대응하는 발송 로그.
// MessageLog(@@unique([patientId, messageType]))는 환자당 타입 하나만 허용해서
// 재등록(예: 3일체험 재신청) 시 유니크 충돌이 나므로 재사용하지 않고 별도 테이블로 분리함 —
// TodoTask 1건마다 로그가 새로 생기니 재등록해도 충돌이 구조적으로 없음.
model ProgramEventLog {
  id               Int        @id @default(autoincrement())
  todoTaskId       Int        @unique
  todoTask         TodoTask   @relation(fields: [todoTaskId], references: [id])
  sentDate         DateTime?
  staffUserId      Int?
  staffUser        StaffUser? @relation("ProgramEventLogStaff", fields: [staffUserId], references: [id])
  skippedAt        DateTime?
  skippedByUserId  Int?
  skippedByUser    StaffUser? @relation("ProgramEventLogSkippedBy", fields: [skippedByUserId], references: [id])
  // 환자발송용 메시지(복사 대상)
  patientMessage   String?
  // 원장용 내부분석(타입/처방방향/상담포인트 등) — 복사 버튼 없이 원장만 보는 용도
  internalAnalysis String?
  createdAt        DateTime   @default(now())
}

model MessageLog {
  id              Int        @id @default(autoincrement())
  patientId       Int
  patient         Patient    @relation(fields: [patientId], references: [id])
  messageType     String // WELCOME | MEETING | DAY2 | DAY7 | THIRD_VISIT
  sentDate        DateTime?
  staffUserId     Int?
  staffUser       StaffUser? @relation(fields: [staffUserId], references: [id])
  skippedAt       DateTime?
  skippedByUserId Int?
  skippedByUser   StaffUser? @relation("MessageLogSkippedBy", fields: [skippedByUserId], references: [id])
  aiDraftContent  String?
  createdAt       DateTime   @default(now())

  @@unique([patientId, messageType])
}

model PatientNote {
  id          Int       @id @default(autoincrement())
  patientId   Int
  patient     Patient   @relation(fields: [patientId], references: [id])
  content     String
  staffUserId Int
  staffUser   StaffUser @relation(fields: [staffUserId], references: [id])
  createdAt   DateTime  @default(now())
}

// 킬팻캡슐 3일체험 등록(구글폼) 응답을 시트에서 폴링해 캐싱해두는 테이블.
// 완전 자동매칭은 하지 않고, 직원이 /prescriptions/new 화면에서 이 목록 중 골라
// surveyDataJson에 채워넣는 반자동 방식의 소스 데이터로만 사용한다.
model SurveyResponseCache {
  id                   Int      @id @default(autoincrement())
  // 시트상 행 식별용(타임스탬프+이름+연락처 조합) — 재폴링 시 중복 적재 방지
  sourceRowId          String   @unique
  respondentName       String
  respondentPhone      String
  // 행 전체를 헤더-값 매핑 JSON 문자열로 보관(텍스트 정리 시 재사용)
  rawDataJson          String
  fetchedAt            DateTime @default(now())
  // 실제 Prescription과의 FK 관계는 두지 않음 — 이 캐시는 어디까지나 선택 참고용 소스라
  // 처방 삭제/재등록 흐름에 얽히지 않게 느슨한 참조(문자열)로만 남긴다(13-4 대비 기초 작업).
  linkedPrescriptionId String?
}

// 상시 안내(휴진 안내, 유의사항, 이벤트 기간 안내 등). WorkTask와 달리 체크/완료 개념이
// 없고, 그냥 조건에 맞으면 홈 화면에 노출되는 읽기 전용 게시물이다.
// startDate/endDate는 Visit.visitDate와 동일한 자정 정규화 원칙(YYYY-MM-DD를 로컬 자정으로
// 파싱)을 따른다. endDate가 null이면 원장이 직접 내릴 때까지 무기한 노출.
// isActive는 종료일 전이라도 원장이 수동으로 내릴 수 있게 하는 별도 스위치 — endDate만으로는
// "아직 기간은 남았지만 지금 당장 내리고 싶다"는 경우를 표현할 수 없기 때문.
model Announcement {
  id          Int       @id @default(autoincrement())
  title       String
  content     String
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdById Int
  createdBy   StaffUser @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
}

model Goal {
  id          Int      @id @default(autoincrement())
  metricKey   String
  periodType  String
  periodStart DateTime
  targetValue Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([metricKey, periodType, periodStart])
}

// 환자 티칭지(14-2 → 14-4, 프로그램 중심) — 규림한의원 핵심 프로그램(약 10개: 다이어트/
// 강근단/보약/추나패키지 등) 단위로 "왜 이 프로그램이 필요한지"를 검사수치/증상 근거로
// 보여주는 구조. 통짜 텍스트(reasoningTemplate)였던 핵심 콘텐츠를 "직원이 채우는 셀링포인트
// 7개 + 원장이 채우는 학술 3개"로 구조화했다 — 협업 입력이라 이 10개 필드는 role 제한 없음
// (환자 핵심프로필/Patient.pastHistory 등과 달리 원장 전용이 아님).
model ProgramTeaching {
  id                    Int     @id @default(autoincrement())
  // 원장실PC↔집PC 콘텐츠 자산 동기화(task.md)용 식별자 — autoincrement id는 PC마다 달라질
  // 수 있어 "같은 레코드"를 판별하는 용도로는 못 쓴다. 화면 노출 없음, export/import
  // 스크립트에서만 사용.
  syncKey               String  @unique @default(cuid())
  programName           String
  // 담당자가 프로그램을 고를 때 참고하는 힌트용 자유텍스트(자동매칭 아님). 예: "허리, 무릎".
  targetSymptomKeywords String?
  // BODY_COMPOSITION | STRENGTH_TEST | null(추나패키지처럼 검사와 무관한 순수 증상기반 프로그램)
  linkedTestType        String?

  // 직원 셀링포인트 3개(환자/한의원/기타 관점) — 전부 nullable, 일부만 채워도 무방
  // (AI 생성 시 채워진 것만 사용). 기존 7필드(접근성/편의성/차별성/효과체감/안전성/
  // 생활적합성/기타)를 AI 재분류해 이 3필드로 통합했다(2026-07-11).
  patientSellingPoints String? // 환자 셀링포인트(환자가 망설이는 이유에 대응)
  clinicSellingPoints  String? // 한의원 셀링포인트(한의원 마케팅 강점)
  etcSellingPoints     String? // 기타

  // 원장 학술 3개 — 셀링포인트와 마찬가지로 전부 nullable.
  academicDefinition String? // 질환 정의(한의학적 정의)
  academicMechanism  String? // 처방 기전(성분/기전 근거)
  academicEvidence   String? // 임상 근거(임상 데이터/개선 사례)

  // 원장님 학술자료 참고이미지 1장(선택) — 업로드 시 서버에서 자동 리사이즈/압축.
  supportImagePath String?
  // 공개 티칭지(/p/{token}) 하단 전환버튼 문구 — 비어있으면 DEFAULT_CTA_LABEL(teaching-pages.ts)
  // 을 그대로 노출한다. 프로그램별로 문구를 다르게 하고 싶을 때만 채운다.
  ctaButtonLabel   String?
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  patientPages     PatientTeachingPage[]
}

// 환자 1명에게 발급된 프로그램 티칭지 인스턴스 — 공개 URL(/p/{token})로 인증 없이 노출된다.
// expiresAt은 이번 단계에서 항상 null(만료 로직 없음, 컬럼만 확장 대비로 미리 준비).
model PatientTeachingPage {
  id                    Int                @id @default(autoincrement())
  token                 String             @unique
  patientId             Int
  patient               Patient            @relation(fields: [patientId], references: [id])
  programTeachingId     Int
  programTeaching       ProgramTeaching    @relation(fields: [programTeachingId], references: [id])
  // 생성 시점의 검사수치 스냅샷(JSON 자유 형식) — linkedTestType이 null인 프로그램이면 null.
  // 이후 검사기준이 바뀌어도 과거 발급 티칭지의 수치가 소급 변경되지 않도록 스냅샷으로 고정.
  snapshotTestValueJson String?
  // 14-10: 단일 텍스트 블록(aiPersonalizedText) 폐기, 5단 구조로 교체 — /p/[token]이
  // headline → personalSubtopic → bodyText → examSummary(있을 때만) → academicHook
  // 순서로 렌더링한다. 실사용 등록 0건 시점에 교체해 별도 데이터 마이그레이션 없음.
  headline              String
  personalSubtopic      String
  bodyText              String
  // 검사 무관 프로그램(linkedTestType null)이면 항상 null.
  examSummary           String?
  academicHook          String
  viewCount             Int                @default(0)
  firstViewedAt         DateTime?
  createdAt             DateTime           @default(now())
  createdByStaffId      Int
  createdByStaff        StaffUser          @relation("TeachingPageCreator", fields: [createdByStaffId], references: [id])
  expiresAt             DateTime?
  shareLinks            PatientShareLink[]
  // 소프트 삭제 원칙(Patient/Program 등과 동일) — 생성목록/드롭다운에서만 숨기고, 이미
  // 발송된 공개 링크(/p/[token], /s/[token])는 isActive와 무관하게 계속 정상 렌더링한다
  // (task.md 지시 — 완전삭제 금지).
  isActive              Boolean            @default(true)
}

// 원장 상담모드(14-5) — 초진뿐 아니라 한약상담/인바디상담 등 프로그램당 여러 차례 이어지는
// 상담을 한차트(직원 메모와 섞이는 곳)와 분리해서 누적 관리한다. 작성/수정은 /consult-mode
// (원장 전용)에서만 이뤄지고, /patients/[patientId]에서는 읽기 전용으로만 노출된다 —
// 서버단 role 재검증은 /api/consultation-notes POST에서 core-profile과 동일하게 수행.
model ConsultationNote {
  id                 Int              @id @default(autoincrement())
  patientId          Int
  patient            Patient          @relation(fields: [patientId], references: [id])
  // 실제 상담이 이뤄진 날짜 — Visit.visitDate와 동일한 자정 정규화 원칙.
  visitDate          DateTime
  consultationTypeId Int
  consultationType   ConsultationType @relation(fields: [consultationTypeId], references: [id])
  rawText            String
  // AI 차팅변환(SOAP) 결과 — 강제 아님, 원장이 버튼을 눌렀을 때만 채워진다.
  convertedChartText String?
  createdByStaffId   Int
  createdByStaff     StaffUser        @relation(fields: [createdByStaffId], references: [id])
  createdAt          DateTime         @default(now())
  // 오타/잘못 기재 정정 목적의 수정 시각만 기록(상세 수정 이력 추적은 불필요, task.md 지시).
  updatedAt          DateTime         @updatedAt
}

// 실시간 활동피드(우측 고정 레일) 전용 로그 — 순위/집계가 아니라 담담한 사실 나열 목적이라
// StaffUser/Patient 어느 쪽이든 될 수 있는 actorId를 FK 없이 느슨하게 둔다(actorType으로 구분).
// label은 이미 완성된 문장을 저장해 화면은 그대로 뿌리기만 한다 — 조회 시점에 이름을
// 다시 조인해서 조립할 필요가 없고, 이후 actor가 삭제/변경돼도 과거 로그 문구가 안전하다.
model ActivityLog {
  id               Int        @id @default(autoincrement())
  actorType        String // STAFF | PATIENT | SYSTEM
  actorId          Int?
  actionType       String // ANNOUNCEMENT_CREATE | WORK_CREATE | WORK_COMPLETE | TALK_CONFIRM | TEACHING_CTA_CLICK | EVENT_CTA_CLICK 등
  label            String
  createdAt        DateTime   @default(now())
  // PATIENT 항목 전용 "확인" 체크(task.md) — 최초 1인만 체크 가능, 체크 자체도 새
  // ActivityLog 항목으로 남는다(그 항목엔 다시 체크박스가 안 붙게 화면에서 구분).
  isChecked        Boolean    @default(false)
  checkedByStaffId Int?
  checkedByStaff   StaffUser? @relation(fields: [checkedByStaffId], references: [id])
  checkedAt        DateTime?
}

// 이벤트 이미지 생성기 1차 버전(AI 생성 > 이벤트 이미지 탭) — 문구를 AI로 완성한 뒤
// 배경 이미지 위에 자동 배치로 합성한 결과를 저장한다. 톡생성기 연동/공개 URL 노출은
// 이번 범위 밖(task.md 지시) — "만들고 저장"까지만.
model EventImage {
  id                  Int                @id @default(autoincrement())
  // ProgramTeaching.syncKey와 동일한 용도(원장실PC↔집PC 동기화 식별자).
  syncKey             String             @unique @default(cuid())
  rawIdea             String
  finalTitle          String
  finalCopy           String
  // 업로드된 배경 원본 — ProgramTeaching.supportImagePath와 동일한 저장 방식(리사이즈 후 저장).
  backgroundImagePath String
  // 브라우저 Canvas로 문구를 합성한 최종 결과 이미지 — 텍스트 화질 손실 방지를 위해
  // 재압축 없이 그대로 저장.
  compositeImagePath  String
  createdByStaffId    Int
  createdByStaff      StaffUser          @relation("EventImageCreator", fields: [createdByStaffId], references: [id])
  createdAt           DateTime           @default(now())
  // 소프트 삭제 원칙 — 삭제 대신 비활성화만.
  isActive            Boolean            @default(true)
  shareLinks          PatientShareLink[]
}

// 환자별 통합 공유링크(14-11) — 프로그램티칭(/p/{token})과 이벤트(EventImage)를 하나의
// 링크(/s/{token})로 묶어서 톡생성기에서 발송 문구에 붙여넣을 수 있게 한다. teachingPageId/
// eventImageId 둘 다 nullable이지만 최소 1개는 있어야 하며(서버단 검증, 둘 다 null이면
// 애초에 링크가 필요 없는 케이스), 같은 조합(patientId+teachingPageId+eventImageId)으로
// 재요청하면 새로 만들지 않고 기존 링크를 재사용한다(lib/share-links.ts).
model PatientShareLink {
  id                    Int                    @id @default(autoincrement())
  token                 String                 @unique
  patientId             Int
  patient               Patient                @relation(fields: [patientId], references: [id])
  teachingPageId        Int?
  teachingPage          PatientTeachingPage?   @relation(fields: [teachingPageId], references: [id])
  eventImageId          Int?
  eventImage            EventImage?            @relation(fields: [eventImageId], references: [id])
  createdByStaffId      Int
  createdByStaff        StaffUser              @relation("ShareLinkCreator", fields: [createdByStaffId], references: [id])
  viewCount             Int                    @default(0)
  firstViewedAt         DateTime?
  createdAt             DateTime               @default(now())
  // 검사톡(task.md) — 인바디/근력/HRV처럼 서로 다른 테이블에 있는 검사기록을 하나의 FK로
  // 묶을 수 없어 별도 조인테이블로 뺐다. 0개면 기존(티칭/이벤트만 있는) 링크와 완전히 동일하게
  // 동작해 하위호환이 저절로 보장된다.
  examLinks             PatientShareLinkExam[]
  // 증상 패턴 프로필(task.md) 4번째 섹션 — 공유링크에서 직접 제출된 응답의 감사 추적용.
  tcmChecklistResponses TcmChecklistResponse[]

  @@index([patientId, teachingPageId, eventImageId])
}

// 검사톡(task.md)이 포함하는 검사기록 1건 = 1행. examType별로 실제 레코드가 각각 다른
// 테이블(BodyCompositionRecord/StrengthTestRecord/HrvTestRecord)에 있어 DB 레벨 FK 대신
// examType(String) + examRecordId 조합으로 참조한다 — TodoTask.taskType, ExamAcademicGuide.
// examType과 동일하게 이 코드베이스가 검사/작업 종류를 문자열 판별자로 다루는 기존 관례를
// 따른 것이며, 향후 검사 종류가 늘어나도 이 테이블/스키마는 값만 늘어날 뿐 마이그레이션이
// 필요 없다(단, 화면 렌더링 쪽은 새 종류마다 분기 코드 추가가 필요 — examination-format.ts와
// 동일한 한계).
model PatientShareLinkExam {
  id           Int              @id @default(autoincrement())
  shareLinkId  Int
  shareLink    PatientShareLink @relation(fields: [shareLinkId], references: [id])
  examType     String
  examRecordId Int
  createdAt    DateTime         @default(now())

  @@index([shareLinkId])
  @@index([examType, examRecordId])
}

// 증상 패턴 프로필(task.md) — HRV 등 검사와 별개로 환자에 종속된 독립 상담 체크리스트.
// "변증 진단표"가 아니라 참고용 프로필이라는 점을 강조하기 위해 한의학 변증명 대신
// 카테고리 코드(EMOTION_STAGNATION 등)로 다룬다(과신 방지, task.md 배경).
// 7개 대분류 1개 = 1행. 문항은 TcmChecklistQuestion에 따로 둔다.
model TcmCategory {
  id                 Int      @id @default(autoincrement())
  categoryCode       String   @unique
  patientLabel       String
  // 치료원칙 — 이번 라운드는 전부 null로 비워둔다(원장이 /settings/exam-guides에서 추후
  // 직접 입력, task.md 지시로 임의 작성 금지).
  treatmentPrinciple String?
  // 위험신호(red flag) 고정문구(task.md 건강 리포트 리뉴얼) — AI가 만들지 않고 원장이 카테고리별로
  // 직접 입력한다(오늘은 담습·부종만 시드값 있음, 나머지는 비워둠). 이 카테고리가 후보로
  // 나왔을 때만 카드로 노출하고, null이면 카드 자체를 숨긴다(HrvTestRecord.aiRedFlagNotice).
  redFlagNotice      String?
  displayOrder       Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  questions      TcmChecklistQuestion[]
  categoryScores TcmCategoryScore[]
}

// 카테고리 1개에 딸린 체크리스트 문항 — 12개 전부 task.md 표의 문구를 그대로 시드한다.
model TcmChecklistQuestion {
  id              Int         @id @default(autoincrement())
  categoryId      Int
  category        TcmCategory @relation(fields: [categoryId], references: [id])
  questionCode    String      @unique
  patientQuestion String
  weight          Int         @default(1)
  displayOrder    Int         @default(0)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())

  answers TcmChecklistAnswer[]

  @@index([categoryId])
}

// 상담설문 응답 1건 = 환자의 설문 작성 세션. 이력 누적 구조(deletedAt 없이 순수 append) —
// 같은 달력월 안에서 재작성하면 UPDATE, 달이 바뀌면 새 행 INSERT(tcm-checklist.ts에서 처리).
// "그외" 자유기록은 점수화 테이블과 분리해 여기 텍스트 필드로 직접 둔다(task.md 지시).
model TcmChecklistResponse {
  id        Int     @id @default(autoincrement())
  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id])

  source             String // "IN_CLINIC" | "SHARE_LINK"
  shareLinkId        Int?
  shareLink          PatientShareLink? @relation(fields: [shareLinkId], references: [id])
  submittedByStaffId Int?
  submittedByStaff   StaffUser?        @relation(fields: [submittedByStaffId], references: [id])

  otherSymptomsText String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers        TcmChecklistAnswer[]
  categoryScores TcmCategoryScore[]

  @@index([patientId])
}

// 문항별 응답값 — 0=없다, 1=경미하다, 2=심하다(task.md 지시로 정수 그대로 저장).
model TcmChecklistAnswer {
  id         Int                  @id @default(autoincrement())
  responseId Int
  response   TcmChecklistResponse @relation(fields: [responseId], references: [id])
  questionId Int
  question   TcmChecklistQuestion @relation(fields: [questionId], references: [id])
  score      Int

  @@unique([responseId, questionId])
}

// 응답 1건의 카테고리별 계산 결과 — 제출 시점 스냅샷(문항이 나중에 바뀌어도 과거 응답의
// "그때 결과"가 보존됨, HrvTestRecord의 AI 코멘트 캐싱과 동일 원칙).
model TcmCategoryScore {
  id          Int                  @id @default(autoincrement())
  responseId  Int
  response    TcmChecklistResponse @relation(fields: [responseId], references: [id])
  categoryId  Int
  category    TcmCategory          @relation(fields: [categoryId], references: [id])
  rawScore    Int
  maxScore    Int
  ratio       Float
  isCandidate Boolean              @default(false)

  @@unique([responseId, categoryId])
}
